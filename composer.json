{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "anhskohbo/no-captcha": "^3.7.0",
        "barryvdh/laravel-dompdf": "^3.1.1",
        "brick/math": "^0.14.1",
        "guzzlehttp/guzzle": "^7.10",
        "intervention/image": "^3.11.5",
        "laravel/socialite": "^5.24.0",
        "maatwebsite/excel": "^3.1",
        "maba/math": "^1.0",
        "nwidart/laravel-modules": "^12.0.4",
        "millat/laravel-hooks": "^1.3",
        "phpmailer/phpmailer": "^7.0",
        "spatie/laravel-activitylog": "^4.10",
        "stripe/stripe-php": "^7.100",
        "yajra/laravel-datatables": "^12.0",
        "milon/barcode": "^12.0",
        "spatie/laravel-translatable": "^6.6",
        "laravel/passport": "^13.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^1.8",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",

        "spatie/laravel-ignition": "^2.9",
        "orangehill/iseed": "^3.1",
        "pestphp/pest-plugin-faker": "^3.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": false,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "joshbrw/laravel-module-installer": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                
            ]
        }
    },
    
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Infoamin\\Installer\\": "packages/infoamin/laravel-installer/src/"
        },
        "files": [
            "app/helpers/helpers.php",
            "app/helpers/strings.php",
            "app/helpers/files.php",
            "app/helpers/langdatetime.php",
            "app/helpers/numbers.php"
        ],
        "classmap": [
            "Modules/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php -r \"if (file_exists(__DIR__ . '/vendor/laravel/boost')) { passthru('php artisan boost:update --ansi'); }\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },

    "minimum-stability": "stable",
    "prefer-stable": true
}
